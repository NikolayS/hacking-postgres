---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title,
  description = 'A public workbench for Postgres hacking sessions, patches, reviews, blockers, and follow-up work.',
} = Astro.props;
const pageTitle = title ? `${title} — Postgres Hacking` : 'Postgres Hacking';
const path = Astro.url.pathname;
const links = [
  ['/', './home'],
  ['/work', './work'],
  ['/todo', './TODO'],
  ['/sessions', './sessions'],
  ['/topics', './topics'],
  ['/people', './people'],
  ['/about', './about'],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0d10" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={new URL(path, Astro.site)} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">skip to content</a>
    <header class="site-header">
      <div class="shell">
        <a class="brand" href="/">hacking.postgres.tv</a>
        <nav class="nav" aria-label="Primary navigation">
          {links.map(([href, label]) => (
            <a href={href} aria-current={path === href || (href !== '/' && path.startsWith(`${href}/`)) ? 'page' : undefined}>{label}</a>
          ))}
          <a class="join" href="https://t.me/postgres_hacking">[join telegram]</a>
        </nav>
      </div>
    </header>
    <main id="content"><slot /></main>
    <footer class="site-footer">
      <div class="shell">
        <span>/* built in public — patches over promises */</span>
        <span>[<a href="https://github.com/NikolayS/hacking-postgres">source</a>] [<a href="https://www.youtube.com/@PostgresTV">PostgresTV</a>]</span>
      </div>
    </footer>
  </body>
</html>
