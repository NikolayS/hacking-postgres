---
import Layout from '../../layouts/Layout.astro';
import SessionRow from '../../components/SessionRow.astro';
import { sessions } from '../../data/sessions';
import { workItems } from '../../data/work';
import type { WorkItem } from '../../data/types';

export function getStaticPaths() {
  return workItems.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props as { item: WorkItem };
const related = sessions.filter((session) => item.sessions.includes(session.video));
---

<Layout title={item.title} description={item.summary}>
  <section class="page-head"><div class="shell"><p class="eyebrow">/projects/{item.slug}</p><h1>{item.title}</h1><p class="lede">{item.summary}</p><div class="actions"><span class={`button state ${item.state}`}>{item.state.replace('-', ' ')}</span>{item.artifacts.map((artifact) => <a class="button" href={artifact.url}>{artifact.label} ↗</a>)}</div></div></section>
  <section class="section"><div class="shell split"><div><div class="section-head"><h2>progress</h2><span class="meta">{item.progress}%</span></div><div class={`progress ${item.state}`} style="height:6px"><span style={`width:${item.progress}%`}></span></div>{item.blocker && <div class="callout" style="margin-top:1.5rem;border-color:var(--danger)"><p><strong>blocker:</strong> {item.blocker}</p></div>}</div><div><h2>next</h2>{item.next.length > 0 ? <ul class="detail-list">{item.next.map((task) => <li>{task}</li>)}</ul> : <p class="lede">Shipped. Watch the back branches and move on.</p>}</div></div></section>
  <section class="section"><div class="shell"><div class="section-head"><h2>sessions</h2><span class="meta">{related.length}</span></div><div class="session-list">{related.map((session) => <SessionRow session={session} />)}</div></div></section>
</Layout>
