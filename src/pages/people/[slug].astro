---
import Layout from '../../layouts/Layout.astro';
import PersonLinks from '../../components/PersonLinks.astro';
import SessionRow from '../../components/SessionRow.astro';
import { sessions } from '../../data/sessions';
import { people, sessionsForPerson } from '../../data/taxonomy';

export function getStaticPaths() {
  return people.map((person) => ({ params: { slug: person.slug }, props: { person } }));
}

const { person } = Astro.props;
const related = sessionsForPerson(sessions, person.slug);
---

<Layout title={person.name}>
  <section class="page-head"><div class="shell"><p class="eyebrow">postgres=# select * from sessions where person = '{person.slug}';</p><h1>{person.name}</h1>{person.recognition && <a class="contributor-recognition" href={person.recognition.url}>{person.recognition.label} ↗</a>}<p class="lede">{person.note} {related.length} sessions in the public archive.</p><PersonLinks links={person.links} /></div></section>
  <section class="section"><div class="shell"><div class="session-list">{related.map((session) => <SessionRow session={session} />)}</div></div></section>
</Layout>
