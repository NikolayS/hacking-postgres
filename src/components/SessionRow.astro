---
import type { Session } from '../data/types';
import { sessionDetails, timestampSeconds } from '../data/session-details';
import { youtubeUrl, youtubeUrlAt } from '../data/sessions';
import { peopleForSession, topicsForSession } from '../data/taxonomy';
const { session } = Astro.props as { session: Session };
const detail = sessionDetails[session.video];
const sessionTopics = topicsForSession(session);
const sessionPeople = peopleForSession(session);
---

<article class="session" data-session data-line={session.line} data-search={`${session.title} ${session.topic} ${detail?.summary ?? ''} ${detail?.chapters.map(({ title }) => title).join(' ') ?? ''} ${session.line} ${sessionTopics.map(({ name }) => name).join(' ')} ${sessionPeople.map(({ name }) => name).join(' ')}`.toLowerCase()}>
  <div>
    <button class="session-video" type="button" data-video={session.video} aria-label={`Play ${session.title}`}>
      <img src={`https://i.ytimg.com/vi/${session.video}/mqdefault.jpg`} alt="" width="320" height="180" loading="lazy" />
      <span>[play]</span>
    </button>
    <div class="session-date"><time datetime={session.date}>{session.date}</time> · {session.duration} · <a href={youtubeUrl(session.video)}>youtube ↗</a></div>
  </div>
  <div>
    <h2><a href={youtubeUrl(session.video)}>{session.title}</a></h2>
    <p class="session-topic">{session.topic}</p>
    {detail
      ? <p class="session-summary">{detail.summary}</p>
      : <p class="session-summary session-summary-pending">Transcript summary and timecodes pending captions.</p>}
    {detail?.chapters.length > 0 && (
      <details class="session-chapters">
        <summary>[timecodes · {detail.chapters.length}]</summary>
        <ol>
          {detail.chapters.map((chapter) => (
            <li>
              <a
                class="session-chapter"
                href={youtubeUrlAt(session.video, timestampSeconds(chapter.at))}
                target="_blank"
                rel="noreferrer"
                data-video={session.video}
                data-start={timestampSeconds(chapter.at)}
                data-session-title={session.title}
              ><time>{chapter.at}</time> {chapter.title}</a>
            </li>
          ))}
        </ol>
      </details>
    )}
    <div class="tag-list" aria-label="Topics and people">
      {sessionTopics.map((topic) => <a class="tag topic-tag" href={`/topics/${topic.slug}/`}>#{topic.name}</a>)}
      {sessionPeople.map((person) => <a class="tag person-tag" href={`/people/${person.slug}/`}>@{person.name}</a>)}
    </div>
    <div class="artifact-list">
      {session.artifacts.map((artifact) => <a href={artifact.url}>{artifact.label}</a>)}
      {session.artifacts.length === 0 && <span class="meta">no public artifact mapped</span>}
    </div>
  </div>
  <div class="session-side">
    <div class={`state ${session.outcome}`}>{session.outcome}</div><br />
    <span class="confidence">{session.confidence} mapping</span>
  </div>
</article>

<script>
  const getVideoDialog = () => {
    const existing = document.querySelector<HTMLDialogElement>('#video-dialog');
    if (existing) return existing;

    const dialog = document.createElement('dialog');
    dialog.id = 'video-dialog';
    dialog.className = 'video-dialog';
    dialog.setAttribute('aria-labelledby', 'video-dialog-title');
    dialog.innerHTML = `
      <div class="video-dialog-frame">
        <header>
          <strong id="video-dialog-title"></strong>
          <button type="button" class="video-dialog-close" aria-label="Close video">[close]</button>
        </header>
        <div class="video-dialog-player"></div>
        <footer><a class="video-dialog-youtube" href="" target="_blank" rel="noreferrer">[open on youtube ↗]</a></footer>
      </div>`;
    document.body.append(dialog);

    const close = () => dialog.close();
    dialog.querySelector<HTMLButtonElement>('.video-dialog-close')?.addEventListener('click', close);
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) close();
    });
    dialog.addEventListener('close', () => {
      dialog.querySelector('.video-dialog-player')?.replaceChildren();
      document.body.classList.remove('video-dialog-open');
    });
    return dialog;
  };

  const openVideoDialog = (video: string, title: string, start = 0) => {
    const dialog = getVideoDialog();
    const iframe = document.createElement('iframe');
    const startParam = start > 0 ? `&start=${start}` : '';
    iframe.src = `https://www.youtube-nocookie.com/embed/${video}?autoplay=1${startParam}`;
    iframe.title = title;
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
    iframe.allowFullscreen = true;
    dialog.querySelector('.video-dialog-player')?.replaceChildren(iframe);
    const heading = dialog.querySelector<HTMLElement>('#video-dialog-title');
    if (heading) heading.textContent = title;
    const youtube = dialog.querySelector<HTMLAnchorElement>('.video-dialog-youtube');
    if (youtube) youtube.href = `https://www.youtube.com/watch?v=${video}${start > 0 ? `&t=${start}s` : ''}`;
    document.body.classList.add('video-dialog-open');
    dialog.showModal();
  };

  document.querySelectorAll<HTMLButtonElement>('.session-video:not([data-wired])').forEach((button) => {
    button.dataset.wired = 'true';
    button.addEventListener('click', () => {
      const video = button.dataset.video;
      if (!video) return;
      const title = button.getAttribute('aria-label')?.replace(/^Play /, '') ?? 'YouTube video';
      openVideoDialog(video, title);
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('.session-chapter:not([data-wired])').forEach((link) => {
    link.dataset.wired = 'true';
    link.addEventListener('click', (event) => {
      const video = link.dataset.video;
      if (!video) return;
      event.preventDefault();
      const start = Number(link.dataset.start ?? 0);
      const chapter = link.textContent?.trim() ?? 'Chapter';
      const sessionTitle = link.dataset.sessionTitle ?? 'YouTube video';
      openVideoDialog(video, `${sessionTitle} — ${chapter}`, start);
    });
  });
</script>
